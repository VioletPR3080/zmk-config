#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp W &kp A &kp S &kp D &kp Q &kp E &kp F
                &kp SPACE &kp RET &kp LSHFT &kp LCTRL
                &kp N1 &kp N2 &kp N3 &kp N4 &kp N5
                &kp LEFT &kp UP &kp DOWN &kp RIGHT
            >;
        };
    };
};
