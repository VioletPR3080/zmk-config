#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp W &kp A &kp S &kp D &kp Q &kp E &kp F
                &kp SPACE &kp RET &kp LSHFT &kp LCTRL
                &bt BT_SEL 0 &bt BT_CLR &bt BT_NXT &bt BT_PRV &kp N5
                &kp LEFT &kp UP &kp DOWN &kp RIGHT
            >;
        };
    };
};
